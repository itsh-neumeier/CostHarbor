# CostHarbor Environment Configuration
# Copy this file to .env and adjust values

# Database
DATABASE_URL=postgresql://costharbor:costharbor@db:5432/costharbor

# Security
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ENCRYPTION_KEY=  # Fernet key for encrypting sensitive config; generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Initial Admin User (created on first start if no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-immediately
ADMIN_EMAIL=admin@example.com

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=production
LOG_LEVEL=info

# File Storage
UPLOAD_DIR=/data/uploads
DOCUMENT_DIR=/data/documents
MAX_UPLOAD_SIZE_MB=50
